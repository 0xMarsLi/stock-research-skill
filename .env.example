# --- LLM (Gemini) ---
GOOGLE_API_KEY=                 # required: https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash  # optional override; flash keeps cost low

# --- Market data ---
# yahoo-finance2 needs no key (price/OHLCV)

# --- Fundamentals / News (Finnhub free tier) ---
FINNHUB_API_KEY=               # optional: https://finnhub.io ; if absent, fundamental/news agents run a "data unavailable" branch
DATA_PROVIDER=finnhub          # reserved switch for future paid providers

# --- Market sentiment (web search to validate our calls) ---
SENTIMENT_PROVIDER=gemini      # "gemini" uses Gemini's built-in Google Search grounding (no extra key)
# TAVILY_API_KEY=              # reserved: future Tavily-backed sentiment provider
