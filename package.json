{
  "name": "stock-research-skill",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Stock research agent skill — deterministic scripts (Minervini Trend Template + CANSLIM + RS Rating) output JSON; the host agent does judgment + web search. No bundled LLM.",
  "scripts": {
    "screen": "tsx scripts/screen.ts",
    "analyze": "tsx scripts/analyze.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "yahoo-finance2": "^3.15.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
